{
  "dataset_path": "data/students.csv.csv",
  "pipeline_dynamics": {
    "input_delay_seconds": 0.0,
    "core_parallelism": 1,
    "stream_queue_max_size": 50
  },
  "schema_mapping": {
    "target_entity": "Student",
    "columns": [
      {
        "source_name": "Name",
        "internal_mapping": "entity_name",
        "data_type": "string"
      },
      {
        "source_name": "Class",
        "internal_mapping": "time_period",
        "data_type": "integer"
      },
      {
        "source_name": "Marks",
        "internal_mapping": "metric_value",
        "data_type": "float"
      }
    ]
  },
  "processing": {
    "operation": "running_average",
    "running_average_window_size": 10
  },
  "visualizations": {
    "telemetry": {
      "show_raw_stream": true,
      "show_processed_stream": true
    },
    "data_charts": [
      {
        "type": "real_time_line_graph_values",
        "title": "Live Student Marks",
        "x_axis": "time_period",
        "y_axis": "metric_value"
      },
      {
        "type": "real_time_line_graph_average",
        "title": "Live Marks Running Average",
        "x_axis": "time_period",
        "y_axis": "computed_metric"
      }
    ]
  }
}